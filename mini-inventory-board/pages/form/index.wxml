<view class="page">
  <view class="form-head">
    <view>
      <view class="form-title">{{isEdit ? '编辑货源' : '新增货源'}}</view>
      <view class="form-subtitle">按业务成交需要录入，选择品类后，型号规格会自动切换成对应字段。</view>
    </view>
    <view wx:if="{{!isEdit}}" class="form-head-actions">
      <button class="batch-entry-button" bindtap="goBatchImport">批量导入</button>
      <button class="image-entry-button" bindtap="goImageRecognize">图片识别</button>
    </view>
  </view>

  <view class="card form-card">
    <view class="block-title">基础信息</view>
    <view class="field">
      <view class="label">货源标题</view>
      <input class="input" value="{{form.title}}" data-field="title" bindinput="onInput" placeholder="例如：R760 AI训练服务器 现货" />
    </view>
    <view class="inline-grid">
      <view class="field">
        <view class="label">品类</view>
        <picker mode="selector" range="{{categoryOptions}}" range-key="label" data-field="category" bindchange="onPickerChange"><view class="picker">{{categoryLabel}}</view></picker>
      </view>
      <view class="field">
        <view class="label">成色</view>
        <picker mode="selector" range="{{conditionOptions}}" range-key="label" data-field="condition" bindchange="onPickerChange"><view class="picker">{{conditionLabel}}</view></picker>
      </view>
    </view>
    <view class="inline-grid">
      <view class="field">
        <view class="label">状态</view>
        <picker mode="selector" range="{{stockStatusOptions}}" range-key="label" data-field="stockStatus" bindchange="onPickerChange"><view class="picker">{{stockStatusLabel}}</view></picker>
      </view>
      <view class="field">
        <view class="label">交期（天）</view>
        <input class="input" type="number" value="{{form.leadTimeDays}}" bindinput="onLeadTimeInput" placeholder="请输入交期天数" />
      </view>
    </view>
    <view class="inline-grid">
      <view class="field">
        <view class="label">数量</view>
        <input class="input" type="number" value="{{form.quantity}}" data-field="quantity" bindinput="onInput" />
      </view>
      <view wx:if="{{showSalePriceField}}" class="field">
        <view class="label">报价单位</view>
        <picker mode="selector" range="{{priceUnitOptions}}" range-key="label" data-field="priceUnit" bindchange="onPickerChange"><view class="picker">{{priceUnitLabel}}</view></picker>
      </view>
    </view>
    <view class="inline-grid">
      <view wx:if="{{showSalePriceField}}" class="field">
        <view class="label">出售价格（{{priceUnitLabel}}）</view>
        <input class="input" type="digit" value="{{form.price}}" data-field="price" bindinput="onInput" placeholder="出售价格" />
      </view>
    </view>

    <view class="field">
      <view class="label">业务类型</view>
      <picker mode="selector" range="{{businessTypeOptions}}" range-key="label" data-field="businessType" bindchange="onPickerChange"><view class="picker">{{businessTypeLabel}}</view></picker>
    </view>
    <view wx:if="{{showRentalFields}}" class="rental-price-block">
      <view class="block-title">租赁报价</view>
      <view class="spec-tip">单位：万/月/台，可按实际货源调整。</view>
      <view class="inline-grid">
        <view wx:for="{{rentalPriceFields}}" wx:key="key" class="field">
          <view class="label">{{item.label}}</view>
          <input class="input" type="digit" value="{{item.value}}" data-field="{{item.key}}" data-index="{{index}}" bindinput="onRentalPriceInput" placeholder="月租报价" />
        </view>
      </view>
    </view>
    <view class="block-title">型号规格</view>
    <view class="spec-tip">当前品类：{{categoryLabel}}。以下字段用于后续搜索、匹配和报价判断。</view>
    <view class="inline-grid spec-grid">
      <view wx:for="{{specFields}}" wx:key="key" class="field">
        <view class="label">{{item.label}}</view>
        <input class="input" value="{{item.value}}" data-field="{{item.key}}" data-index="{{index}}" bindinput="onSpecInput" placeholder="{{item.placeholder}}" />
      </view>
    </view>


    <view class="block-title">交易与质保</view>
    <view class="inline-grid">
      <view class="field"><view class="label">质保说明</view><input class="input" value="{{form.warranty}}" data-field="warranty" bindinput="onInput" placeholder="例如：7天包换 / 原厂保" /></view>
      <view class="field"><view class="label">发票类型</view><input class="input" value="{{form.invoiceType}}" data-field="invoiceType" bindinput="onInput" placeholder="普票 / 专票 / 不含票" /></view>
    </view>
    <view class="inline-grid">
      <view class="field"><view class="label">包装状态</view><input class="input" value="{{form.packageStatus}}" data-field="packageStatus" bindinput="onInput" placeholder="原箱 / 散装 / 托盘" /></view>
      <view class="field"><view class="label">SN/批次</view><input class="input" value="{{form.serialNumber}}" data-field="serialNumber" bindinput="onInput" placeholder="可填SN、批次或资产号" /></view>
    </view>
    <view class="inline-grid">
      <view class="field"><view class="label">付款方式</view><input class="input" value="{{form.paymentTerms}}" data-field="paymentTerms" bindinput="onInput" placeholder="款到发货 / 月结 / 定金" /></view>
      <view class="field"><view class="label">最小起订量</view><input class="input" type="number" value="{{form.minOrderQuantity}}" data-field="minOrderQuantity" bindinput="onInput" /></view>
    </view>
    <view class="inline-grid">
      <view class="field"><view class="label">仓库/提货点</view><input class="input" value="{{form.warehouse}}" data-field="warehouse" bindinput="onInput" placeholder="例如：深圳坂田仓" /></view>
      <view class="field"><view class="label">检测报告</view><input class="input" value="{{form.qualityReport}}" data-field="qualityReport" bindinput="onInput" placeholder="已测 / 待测 / 可提供" /></view>
    </view>
    <view class="block-title">货主信息</view>
    <view class="field"><view class="label">货源类型</view><picker mode="selector" range="{{sourceTypeOptions}}" range-key="label" data-field="sourceType" bindchange="onPickerChange"><view class="picker">{{sourceTypeLabel}}</view></picker></view>
    <view class="field">
      <textarea class="textarea" value="{{form.ownerInfo}}" data-field="ownerInfo" bindinput="onInput" maxlength="300" placeholder="请填写货主信息，此信息仅上传者、对应组别经理、总经理可见，其他成员无法查看"></textarea>
    </view>
    <view class="block-title">联系方式</view>
    <view class="inline-grid">
      <view class="field"><view class="label">联系人</view><input class="input readonly-input" value="{{form.contactName}}" placeholder="自动关联账号姓名" disabled /></view>
      <view class="field"><view class="label">电话/微信</view><input class="input readonly-input" value="{{form.contactMethod}}" placeholder="自动关联账号电话" disabled /></view>
    </view>
    <view class="field"><view class="label">地区</view><input class="input" value="{{form.location}}" data-field="location" bindinput="onInput" placeholder="例如：深圳" /></view>

    <view class="block-title">图片与备注</view>
    <view class="upload-row">
      <button class="button-ghost upload-button" bindtap="chooseImages">上传图片/视频</button>
      <text class="upload-tip">最多6个，用于记录实物、SN或配置截图。</text>
    </view>
    <view class="image-grid" wx:if="{{form.mediaFiles.length > 0}}">
      <view wx:for="{{form.mediaFiles}}" wx:key="url" class="image-cell">
        <image wx:if="{{item.type !== 'video'}}" src="{{item.url}}" data-url="{{item.url}}" mode="aspectFill" class="preview-image" bindtap="previewMedia" />
        <video wx:else src="{{item.url}}" data-url="{{item.url}}" class="preview-image" controls="{{false}}" show-center-play-btn="{{true}}" bindtap="previewVideo"></video>
        <view class="remove-image" data-index="{{index}}" bindtap="removeImage">删除</view>
      </view>
    </view>
    <checkbox-group bindchange="onUrgentChange" class="urgent-row">
      <label class="urgent-label"><checkbox value="urgent" checked="{{form.isUrgent}}" color="#c25c39" />标记紧急</label>
    </checkbox-group>
    <view class="field"><view class="label">备注</view><textarea class="textarea" value="{{form.remark}}" data-field="remark" bindinput="onInput" maxlength="300" placeholder="可填写交付限制、特殊条款、客户关注点等"></textarea></view>

    <button class="button-primary submit-button" bindtap="submitForm">提交货源</button>
  </view>
</view>
