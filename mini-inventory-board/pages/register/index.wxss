.register-page {
  padding-top: 28rpx;
}

.register-hero {
  padding: 30rpx;
}

.register-card {
  padding: 28rpx;
}

.register-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #133a5e;
}

.register-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7a90;
  line-height: 1.7;
}

.status-block {
  padding: 10rpx 0 0;
}

.status-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #133a5e;
}

.status-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7a90;
  line-height: 1.7;
}

.submit-button {
  margin-top: 16rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.code-input {
  flex: 1;
  min-width: 0;
}

.code-button {
  width: 210rpx;
  min-height: 78rpx;
  line-height: 78rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
