<view class="page register-page">
  <view class="card hero register-hero">
    <view class="hero-title">账号登录</view>
    <view class="hero-subtitle">填写姓名和手机号，核实账号存在后，通过手机验证码进入系统。</view>
  </view>

  <view class="card register-card">
    <view class="field">
      <view class="label">姓名</view>
      <input class="input" value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="请输入姓名" />
    </view>
    <view class="field">
      <view class="label">手机号</view>
      <input class="input" type="number" value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="请输入手机号" />
    </view>
    <view class="field">
      <view class="label">验证码</view>
      <view class="code-row">
        <input class="input code-input" type="number" value="{{form.smsCode}}" data-field="smsCode" bindinput="onInput" placeholder="请输入验证码" />
        <button class="button-ghost code-button" bindtap="requestSmsCode">获取验证码</button>
      </view>
    </view>

    <view wx:if="{{statusText}}" class="status-desc">{{statusText}}</view>
    <button class="button-primary submit-button" bindtap="login">登录</button>
  </view>
</view>
