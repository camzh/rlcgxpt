.batch-page {
  padding-bottom: 150rpx;
}

.form-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.form-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6d7f93;
}

.import-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.import-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.import-button,
.parse-button {
  min-height: 82rpx;
  line-height: 82rpx;
  margin: 0;
}

.import-tip {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a98ab;
}

.ocr-preview {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #f6f9fc;
}

.ocr-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 12rpx;
  background: #eef3f8;
}

.ocr-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.5;
}
.import-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 260rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f6f9fc;
  color: #17324d;
  font-size: 24rpx;
  line-height: 1.5;
}

.parse-button {
  margin-top: 18rpx;
}

.invalid-card {
  border-color: #f0b49b;
}

.error-text {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #fff3ee;
  color: #b24f2e;
  font-size: 22rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.remove-button {
  width: 132rpx;
  min-height: 62rpx;
  line-height: 62rpx;
  margin: 0;
  padding: 0;
  font-size: 22rpx;
}

.fixed-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(19, 58, 94, 0.08);
}

.action-button {
  min-height: 88rpx;
  line-height: 88rpx;
  margin: 0;
}
.inventory-card {
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.urgent-card {
  border-color: #f0b49b;
  background: #fffaf7;
}

.inventory-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.inventory-main {
  flex: 1;
  min-width: 0;
}

.inventory-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17324d;
}

.inventory-model {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #4f6278;
}

.urgent-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
  background: #c25c39;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx 20rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f5;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #8a98ab;
}

.cell-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #17324d;
  font-weight: 600;
  line-height: 1.35;
}

.price {
  color: #c25c39;
}