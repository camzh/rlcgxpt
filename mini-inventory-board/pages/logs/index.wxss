.activity-page {
  padding-top: 24rpx;
}

.board-header {
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.log-card-item {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e4ebf2;
  background: #ffffff;
}

.log-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.log-action {
  font-size: 28rpx;
  font-weight: 700;
  color: #17324d;
}

.log-target {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #17324d;
}

.log-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
  line-height: 1.5;
}