.admin-page {
  padding-top: 24rpx;
}

.board-header {
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.kpi-card {
  padding: 18rpx 8rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
  text-align: center;
}

.kpi-value {
  display: block;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #133a5e;
}

.kpi-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
}

.approval-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.summary-card {
  padding: 20rpx 14rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.summary-value {
  display: block;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 800;
  color: #133a5e;
}

.summary-label {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.approval-card,
.review-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.approval-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.approval-name,
.review-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17324d;
}

.approval-meta,
.review-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #72839a;
}

.approval-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.review-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 0;
  box-sizing: border-box;
}

.admin-tool-button {
  width: 100%;
  min-width: 0;
  min-height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  padding: 0;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.review-action-button {
  flex: 0 0 132rpx;
  width: 132rpx;
  max-width: 132rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  font-size: 23rpx;
}

.approval-summary-four {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}
