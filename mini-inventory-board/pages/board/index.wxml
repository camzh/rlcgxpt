<view class="page board-page">
  <view class="board-header">
    <view class="board-title-wrap">
      <view class="page-title">润六尺供需平台</view>
    </view>
    <button class="board-add-button" bindtap="goCreate">+ 新增</button>
  </view>

  <view class="toolbar">
    <input class="search-input" placeholder="搜索品类、型号、配置、联系人、地区" value="{{keyword}}" bindinput="onKeywordChange" />
  </view>

  <scroll-view class="status-scroll" scroll-x enable-flex>
    <view wx:for="{{statusOptions}}" wx:key="value" class="status-chip {{selectedStatus === item.value ? 'status-chip-active' : ''}} {{item.value === 'urgent' ? 'status-chip-urgent' : ''}}" data-value="{{item.value}}" bindtap="onStatusChange">{{item.label}}</view>
  </scroll-view>

  <scroll-view class="status-scroll source-scroll" scroll-x enable-flex >
    <view wx:for="{{currentSourceOptions}}" wx:key="value" class="status-chip {{selectedSource === item.value ? 'status-chip-active' : ''}}" data-value="{{item.value}}" bindtap="onSourceChange">{{item.label}}</view>
  </scroll-view>

  <view class="pool-row">
    <view class="pool-tab {{activePool === 'supply' ? 'pool-tab-active' : ''}}" data-pool="supply" bindtap="switchPool">
      <text>货源池</text>
      <text class="pool-count">{{supplyList.length}}</text>
    </view>
    <view class="pool-tab {{activePool === 'demand' ? 'pool-tab-active' : ''}}" data-pool="demand" bindtap="switchPool">
      <text>需求池</text>
      <text class="pool-count">{{demandList.length}}</text>
    </view>
  </view>

  <view wx:if="{{activePool === 'supply'}}">
    <view wx:if="{{supplyList.length === 0}}" class="card empty-card">
      <view class="empty-title">当前没有货源</view>
      <view class="muted">可先新增，或调整筛选条件。</view>
    </view>
    <view wx:for="{{supplyList}}" wx:key="id" class="inventory-card {{item.isUrgent ? 'urgent-card' : ''}}" bindtap="goDetail" data-id="{{item.id}}" data-type="supply">
      <view class="inventory-top">
        <view class="inventory-main">
          <view class="inventory-title"><text wx:if="{{item.isUrgent}}" class="urgent-badge">急</text>{{item.cardTitle || item.displayTitle || item.title}}</view>
          <view class="inventory-model">{{item.cardSubtitle || item.category || item.model}}</view>
        </view>
        <view class="status-tag {{item.cardStatusClass}}">{{item.cardStatusText}}</view>
      </view>
      <view class="business-grid">
        <view><text class="cell-label">价格</text><text class="cell-value price">{{item.priceLabel}}</text></view>
        <view><text class="cell-label">数量</text><text class="cell-value">{{item.quantity}}</text></view>
        <view><text class="cell-label">地区/交期</text><text class="cell-value">{{item.location}} · {{item.leadTimeText}}</text></view>
        <view><text class="cell-label">联系人</text><text class="cell-value">{{item.creatorContactText || item.creatorName}}</text></view>
        <view wx:if="{{item.rentalLineText}}" class="rental-grid-item">
          <text class="cell-label">租赁价格</text>
          <text class="cell-value rental-value">{{item.rentalLineText}}</text>
        </view>
      </view>
      <view class="inventory-foot">
        <text class="muted">{{item.ownerLabel}}</text>
        <text class="muted">{{item.updatedAtText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{activePool === 'demand'}}">
    <view wx:if="{{demandList.length === 0}}" class="card empty-card">
      <view class="empty-title">当前没有需求</view>
      <view class="muted">可先新增需求，或调整筛选条件。</view>
    </view>
    <view wx:for="{{demandList}}" wx:key="id" class="inventory-card {{item.isUrgent ? 'urgent-card' : ''}}" bindtap="goDetail" data-id="{{item.id}}" data-type="demand">
      <view class="inventory-top">
        <view class="inventory-main">
          <view class="inventory-title"><text wx:if="{{item.isUrgent}}" class="urgent-badge">急</text>{{item.cardTitle || item.title}}</view>
          <view class="inventory-model">{{item.cardSubtitle || item.customerTag || item.contactName}}</view>
        </view>
        <view class="status-tag {{item.cardStatusClass}}">{{item.cardStatusText}}</view>
      </view>
      <view class="business-grid">
        <view><text class="cell-label">预算</text><text class="cell-value price">{{item.budgetText}}</text></view>
        <view><text class="cell-label">数量</text><text class="cell-value">{{item.quantity}}</text></view>
        <view><text class="cell-label">地区/交期</text><text class="cell-value">{{item.region}} · {{item.deliveryDate}}</text></view>
        <view><text class="cell-label">联系人</text><text class="cell-value">{{item.creatorContactText || item.creatorName}}</text></view>
        <view wx:if="{{item.rentalLineText}}" class="rental-grid-item">
          <text class="cell-label">租赁预算</text>
          <text class="cell-value rental-value">{{item.rentalLineText}}</text>
        </view>
      </view>
      <view class="inventory-foot">
        <text class="muted">{{item.customerTag}}</text>
        <text class="muted">{{item.updatedAtText}}</text>
      </view>
    </view>
  </view>
</view>
