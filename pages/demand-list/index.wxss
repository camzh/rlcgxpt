.board-page {
  padding-top: 24rpx;
}

.board-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.kpi-card {
  padding: 18rpx 8rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
  text-align: center;
}

.kpi-value {
  display: block;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #133a5e;
}

.kpi-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
}

.toolbar {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.toolbar .search-input {
  margin-top: 16rpx;
}

.status-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 12rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #dfe8f1;
  border-radius: 999rpx;
  color: #4c617c;
  font-size: 24rpx;
}

.status-chip-active {
  background: #133a5e;
  border-color: #133a5e;
  color: #ffffff;
}

.section-row {
  margin: 26rpx 4rpx 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.inventory-card {
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.inventory-main {
  flex: 1;
  min-width: 0;
}

.inventory-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17324d;
}

.inventory-model {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6d7f93;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx 20rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f5;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #8a98ab;
}

.cell-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #17324d;
  font-weight: 600;
  line-height: 1.35;
}

.price {
  color: #c25c39;
}

.inventory-foot {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 22rpx;
}

.empty-card {
  padding: 40rpx 32rpx;
  text-align: center;
}