.board-page {
  padding-top: 24rpx;
  padding-bottom: 260rpx;
}

.board-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  text-align: center;
}

.board-title-wrap {
  width: 100%;
  min-width: 0;
}

.board-add-button {
  position: fixed;
  right: 34rpx;
  bottom: calc(138rpx + env(safe-area-inset-bottom));
  z-index: 998;
  min-width: 168rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: #133a5e;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 850;
  box-shadow: 0 14rpx 34rpx rgba(19, 58, 94, 0.24);
}

.board-add-button::after {
  border: none;
}

.page-title {
  font-size: 70rpx;
  line-height: 1.08;
  font-weight: 1000;
  letter-spacing: 2rpx;
  color: #17324d;
  text-shadow: 0.6rpx 0 #17324d, -0.6rpx 0 #17324d;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.kpi-card {
  padding: 18rpx 8rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
  text-align: center;
}

.kpi-value {
  display: block;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #133a5e;
}

.kpi-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
}

.toolbar {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.status-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 12rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #dfe8f1;
  border-radius: 999rpx;
  color: #4c617c;
  font-size: 24rpx;
}

.status-chip-active {
  background: #133a5e;
  border-color: #133a5e;
  color: #ffffff;
}

.pool-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.pool-tab {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
  color: #17324d;
  font-size: 30rpx;
  font-weight: 800;
}

.pool-tab-active {
  background: #133a5e;
  border-color: #133a5e;
  color: #ffffff;
}

.pool-count {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.78;
}

.inventory-card {
  margin-top: 14rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.urgent-card {
  border-color: #f0b49b;
  background: #fffaf7;
}

.inventory-main {
  flex: 1;
  min-width: 0;
}

.inventory-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17324d;
}

.urgent-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
  background: #c25c39;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.inventory-model {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6d7f93;
}

.business-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx 20rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f5;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #8a98ab;
}

.cell-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #17324d;
  font-weight: 600;
  line-height: 1.35;
}

.price {
  color: #c25c39;
}

.inventory-foot {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 22rpx;
}

.empty-card {
  margin-top: 14rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.load-more-hint {
  text-align: center;
  padding: 24rpx 0;
  color: #9ba8bb;
  font-size: 26rpx;
}

.status-chip-urgent {
  border-color: #f0b49b;
  color: #b24f2e;
}

.status-chip-urgent.status-chip-active {
  background: #c25c39;
  border-color: #c25c39;
  color: #ffffff;
}
.inventory-card .inventory-title {
  color: #17324d;
  opacity: 1;
}

.inventory-card .inventory-model {
  color: #4f6278;
  opacity: 1;
  min-height: 34rpx;
}
.status-rent {
  background: #e7f2ed;
  color: #216149;
}

.rental-line {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #f2f7f4;
  color: #216149;
  font-size: 22rpx;
  line-height: 1.45;
}
.rental-value {
  color: #216149;
}

.rental-grid-item {
  grid-column: 1 / -1;
}

.rental-value {
  color: #216149;
}

.board-page .inventory-top {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10rpx;
  align-items: flex-start;
}

.board-page .inventory-main {
  min-width: 0;
  width: 100%;
}

.board-page .status-tag {
  max-width: 128rpx;
  padding: 6rpx 12rpx;
  white-space: nowrap;
}

.board-page .inventory-model {
  width: 100%;
  white-space: normal;
  overflow: visible;
  text-overflow: clip;
  min-height: 0;
}