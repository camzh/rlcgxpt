.metric-list-page {
  padding-top: 24rpx;
}

.metric-card-item {
  margin-top: 16rpx;
  padding: 22rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.metric-item-main {
  min-width: 0;
  flex: 1;
}

.metric-item-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #17324d;
}
