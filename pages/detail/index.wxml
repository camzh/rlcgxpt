<view class="page detail-page">
  <view wx:if="{{item}}" class="detail-wrap" id="detailPoster">
    <view class="detail-head">
      <view class="detail-title"><text wx:if="{{item.isUrgent}}" class="urgent-badge">急</text>{{type === 'demand' ? item.title : item.displayTitle}}</view>
      <view class="status-tag {{type === 'demand' ? item.cardStatusClass : item.statusMeta.className}}">{{type === 'demand' ? item.statusText : item.statusMeta.text}}</view>
    </view>
    <view class="detail-subtitle" wx:if="{{type === 'demand'}}">{{item.customerTag}} · {{item.brand}} · {{item.model}}</view>
    <view class="detail-subtitle" wx:else>{{item.category}} · {{item.condition}} · {{item.stockStatus}} · {{item.brand}} {{item.model}}</view>

    <view class="summary-grid">
      <view class="summary-item"><text class="meta-label">数量</text><text class="meta-value">{{item.quantity}}</text></view>
      <view class="summary-item"><text class="meta-label">地区</text><text class="meta-value">{{item.region || item.location}}</text></view>
      <view class="summary-item"><text class="meta-label">交期</text><text class="meta-value">{{type === 'supply' ? item.leadTimeText : (item.deliveryDate || '待确认')}}</text></view>
      <view class="summary-item"><text class="meta-label">联系</text><text class="meta-value">{{item.contactMethod || item.contactPhone || item.followOwnerName || item.creatorName || '暂无'}}</text></view>
    </view>

    <view class="card block" wx:if="{{type === 'demand'}}">
      <view class="block-title">需求信息</view>
      <view class="field-row"><text class="field-label">客户标签</text><text>{{item.customerTag}}</text></view>
      <view class="field-row"><text class="field-label">品牌</text><text>{{item.brand}}</text></view>
      <view class="field-row"><text class="field-label">型号</text><text>{{item.model}}</text></view>
      <view class="field-row"><text class="field-label">GPU</text><text>{{item.gpu || '未填写'}}</text></view>
      <view class="field-row"><text class="field-label">预算</text><text>{{item.budgetText}}</text></view>
      <view class="field-row"><text class="field-label">对接人</text><text>{{item.contactName}}</text></view>
      <view class="field-row"><text class="field-label">电话</text><text>{{item.contactPhone}}</text></view>
      <view wx:if="{{item.usageScenario}}" class="field-row"><text class="field-label">使用场景</text><text>{{item.usageScenario}}</text></view>
      <view wx:if="{{item.acceptableCondition}}" class="field-row"><text class="field-label">成色要求</text><text>{{item.acceptableCondition}}</text></view>
      <view wx:if="{{item.invoiceRequired}}" class="field-row"><text class="field-label">发票要求</text><text>{{item.invoiceRequired}}</text></view>
      <view wx:if="{{item.offlineReviewStatus === 'pending'}}" class="field-row"><text class="field-label">下架审核</text><text>审核中</text></view>
      <view class="remark-box">{{item.remark || '暂无备注'}}</view>
    </view>

    <view class="card block" wx:if="{{type === 'supply'}}">
      <view class="block-title">货源信息</view>
      <view class="field-row"><text class="field-label">品类</text><text>{{item.category}}</text></view>
      <view class="field-row"><text class="field-label">成色</text><text>{{item.condition}}</text></view>
      <view class="field-row"><text class="field-label">库存状态</text><text>{{item.stockStatus}}</text></view>
      <view class="field-row"><text class="field-label">交期</text><text>{{item.leadTimeText}}</text></view>
      <view class="field-row"><text class="field-label">价格</text><text>{{item.priceLabel}}</text></view>
      <view class="field-row"><text class="field-label">来源</text><text>{{item.sourceTypeText}}</text></view>
      <view wx:if="{{item.canViewOwnerInfo && item.ownerInfo}}" class="field-row"><text class="field-label">货主信息</text><text>{{item.ownerInfo}}</text></view>
      <view class="field-row"><text class="field-label">联系人</text><text>{{item.contactName || '未填写'}}</text></view>
      <view class="field-row"><text class="field-label">电话/微信</text><text>{{item.contactMethod || '未填写'}}</text></view>
      <view wx:if="{{item.warranty}}" class="field-row"><text class="field-label">质保</text><text>{{item.warranty}}</text></view>
      <view wx:if="{{item.invoiceType}}" class="field-row"><text class="field-label">发票</text><text>{{item.invoiceType}}</text></view>
      <view wx:if="{{item.packageStatus}}" class="field-row"><text class="field-label">包装</text><text>{{item.packageStatus}}</text></view>
      <view wx:if="{{item.warehouse}}" class="field-row"><text class="field-label">仓库</text><text>{{item.warehouse}}</text></view>
      <view wx:if="{{item.completionReviewStatus === 'pending'}}" class="field-row"><text class="field-label">完成审核</text><text>审核中</text></view>
      <view wx:if="{{item.offlineReviewStatus === 'pending'}}" class="field-row"><text class="field-label">下架审核</text><text>审核中</text></view>
      <view wx:if="{{item.offlineReason}}" class="field-row"><text class="field-label">下架原因</text><text>{{item.offlineReason}}</text></view>
      <view class="remark-box">{{item.remark || '暂无备注'}}</view>
    </view>

    <view class="card block" wx:if="{{item.mediaFiles.length > 0}}">
      <view class="block-title">图片与视频</view>
      <view class="detail-image-grid">
        <view wx:for="{{item.mediaFiles}}" wx:key="url" class="detail-media-cell">
          <image wx:if="{{item.type !== 'video'}}" src="{{item.url}}" data-url="{{item.url}}" mode="aspectFill" class="detail-image" bindtap="previewMedia" />
          <video wx:else src="{{item.url}}" data-url="{{item.url}}" class="detail-image detail-video" controls="{{true}}" show-center-play-btn="{{true}}" bindtap="previewVideo"></video>
        </view>
      </view>
    </view>

    <view class="card block" wx:if="{{type === 'supply'}}">
      <view class="block-title">型号规格</view>
      <view wx:if="{{item.specPairs.length === 0}}" class="muted">未填写规格参数</view>
      <view wx:for="{{item.specPairs}}" wx:key="key" class="field-row"><text class="field-label">{{item.label}}</text><text>{{item.value}}</text></view>
    </view>

    <view class="card block" wx:if="{{type === 'supply'}}">
      <view class="block-title">最近动态</view>
      <view wx:if="{{logs.length === 0}}" class="muted">暂无动态</view>
      <view wx:for="{{logs}}" wx:key="id" class="match-row">
        <view class="match-title">{{item.actionText}}</view>
        <view class="match-meta">{{item.operatorName}} · {{item.createdAtText}}</view>
        <view wx:if="{{item.remark}}" class="match-remark">{{item.remark}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{item && item.status === 'following' && canCancelFollow}}" class="fixed-actions">
    <button class="button-ghost action-button" bindtap="saveLongImage">保存</button>
    <button wx:if="{{canOperate}}" class="button-ghost action-button" bindtap="editItem">编辑</button>
    <button class="button-warn action-button" bindtap="cancelFollow">取消跟进</button>
    <button wx:if="{{canOperate}}" class="button-primary action-button" bindtap="markSold">完成</button>
    <button wx:if="{{canOperate}}" class="button-warn action-button" bindtap="markOffline">{{type === 'demand' ? '下线' : '下架'}}</button>
    <button wx:if="{{canForceDeleteDemand}}" class="button-warn action-button" bindtap="forceDeleteDemand">删除</button>
  </view>
  <view wx:elif="{{item}}" class="fixed-actions">
    <button class="button-ghost action-button" bindtap="saveLongImage">保存</button><button wx:if="{{canOperate}}" class="button-ghost action-button" bindtap="editItem">编辑</button>
    <button wx:if="{{canOperate && item.status !== 'following'}}" class="button-ghost action-button" bindtap="markFollowing">跟进</button>
    <button wx:if="{{canOperate}}" class="button-primary action-button" bindtap="markSold">完成</button>
    <button wx:if="{{canOperate}}" class="button-warn action-button" bindtap="markOffline">{{type === 'demand' ? '下线' : '下架'}}</button>
    <button wx:if="{{canForceDeleteDemand}}" class="button-warn action-button" bindtap="forceDeleteDemand">删除</button>
  </view>
  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
</view>
