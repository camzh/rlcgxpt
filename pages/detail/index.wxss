.detail-page {
  padding-bottom: 220rpx;
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.detail-title {
  flex: 1;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #17324d;
}

.detail-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.urgent-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-right: 10rpx;
  border-radius: 8rpx;
  background: #c25c39;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.summary-item {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.field-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  font-size: 26rpx;
  color: #17324d;
}

.field-label {
  flex-shrink: 0;
  color: #8a98ab;
}

.remark-box {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f6f9fc;
  color: #3b4a5f;
  font-size: 24rpx;
  line-height: 1.6;
}

.detail-image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.detail-image {
  width: 100%;
  height: 150rpx;
  border-radius: 14rpx;
  background: #eef3f8;
}

.detail-media-cell {
  width: 100%;
  height: 150rpx;
}

.detail-video {
  display: block;
  overflow: hidden;
}

.match-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.match-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17324d;
}

.match-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
  line-height: 1.5;
}

.fixed-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(19, 58, 94, 0.08);
  box-sizing: border-box;
}

.action-button {
  flex: 1 1 0;
  min-width: 0;
  width: 100%;
  min-height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-size: 26rpx;
  text-align: center;
}

.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750px;
  height: 1200px;
}
