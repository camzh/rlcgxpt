.form-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.form-head-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.batch-entry-button,
.image-entry-button {
  flex-shrink: 0;
  width: 164rpx;
  height: 68rpx;
  line-height: 66rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-sizing: border-box;
  box-shadow: 0 8rpx 18rpx rgba(19, 58, 94, 0.08);
}

.batch-entry-button {
  background: #eef4fa;
  color: #133a5e;
  border: 2rpx solid #b9cde0;
}

.image-entry-button {
  background: #fff3ee;
  color: #b24f2e;
  border: 2rpx solid #f0b49b;
}

.batch-entry-button::after,
.image-entry-button::after {
  border: none;
}

.form-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.form-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7f93;
}

.form-card {
  margin-top: 22rpx;
  padding: 30rpx;
}

.form-card .field {
  margin-bottom: 24rpx;
}

.form-card .inline-grid {
  gap: 22rpx 24rpx;
}

.form-card .readonly-input {
  background: #f3f7fb;
  color: #506176;
}

.urgent-row {
  margin: 14rpx 0 26rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #fff7f2;
  border: 1rpx solid #f0d2c2;
}

.urgent-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #9f4527;
}

.urgent-label checkbox {
  transform: scale(1.22);
  transform-origin: left center;
  margin-right: 8rpx;
}

.submit-button {
  margin-top: 12rpx;
  min-height: 88rpx;
  line-height: 88rpx;
}

.upload-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.upload-button {
  width: 210rpx;
  min-height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  font-size: 24rpx;
}

.upload-tip {
  flex: 1;
  font-size: 22rpx;
  color: #8a98ab;
  line-height: 1.5;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.image-cell {
  position: relative;
  height: 150rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eef3f8;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 20rpx;
}
