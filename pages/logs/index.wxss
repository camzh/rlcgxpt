.activity-page {
  padding-top: 20rpx;
}

.log-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.log-header-main {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #17324d;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: #6d7f93;
  word-break: break-word;
}

.export-trigger {
  width: 112rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  border: 0;
  background: #17324d;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 58rpx;
}

.export-trigger::after {
  border: 0;
}

.filter-panel {
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e4ebf2;
  background: #ffffff;
}

.filter-panel-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.filter-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #17324d;
}

.filter-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6d7f93;
}

.advanced-body {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf1f6;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.search-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 12rpx;
}

.filter-picker,
.filter-input {
  height: 62rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  border: 1rpx solid #dce5ee;
  background: #f9fbfd;
  color: #17324d;
  font-size: 23rpx;
}

.filter-picker {
  padding: 0 14rpx;
  line-height: 60rpx;
}

.filter-input {
  padding: 0 14rpx;
}

.filter-actions {
  display: flex;
  justify-content: flex-start;
  margin-top: 12rpx;
}

.clear-filter-action {
  display: inline-flex;
  align-items: center;
  height: 50rpx;
  margin: 0;
  padding: 0;
  color: #1769e0;
  font-size: 23rpx;
  line-height: 50rpx;
  text-align: left;
}

.export-status {
  margin-bottom: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background: #eef8f1;
  color: #237a3b;
  font-size: 23rpx;
}

.date-section {
  margin-top: 18rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.date-label {
  font-size: 26rpx;
  font-weight: 800;
  color: #17324d;
}

.date-count {
  font-size: 22rpx;
  color: #8a98ab;
}

.log-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 52rpx;
  gap: 14rpx;
  padding: 18rpx;
  margin-top: 12rpx;
  border: 1rpx solid #e4ebf2;
  border-radius: 8rpx;
  background: #ffffff;
}

.log-card {
  box-sizing: border-box;
}

.log-time {
  padding-top: 2rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #6d7f93;
}

.log-content {
  min-width: 0;
}

.log-line-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.operator-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #17324d;
}

.action-name {
  font-size: 26rpx;
  color: #273f56;
}

.type-chip {
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  font-weight: 700;
}

.type-supply {
  background: #eaf2ff;
  color: #1769e0;
}

.type-demand {
  background: #eef8f1;
  color: #237a3b;
}

.object-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #17324d;
  line-height: 1.45;
  word-break: break-word;
}

.change-line,
.remark-line {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #53667a;
  word-break: break-word;
}

.detail-toggle {
  padding-top: 2rpx;
  color: #1769e0;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: right;
}

.detail-block {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #f7f9fc;
}

.detail-row {
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 12rpx;
  padding: 6rpx 0;
}

.detail-label {
  color: #6d7f93;
  font-size: 22rpx;
  line-height: 1.5;
}

.detail-value {
  color: #17324d;
  font-size: 23rpx;
  line-height: 1.5;
  word-break: break-word;
}

.log-empty {
  margin-top: 24rpx;
}
