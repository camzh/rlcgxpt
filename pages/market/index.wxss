.market-card {
  padding: 30rpx;
}

.market-hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.product-picker {
  min-width: 172rpx;
  max-width: 236rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #133a5e;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.market-stat {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.market-stat .stat-value {
  color: #133a5e;
}

.market-stat .stat-label {
  color: #5f7288;
}

.quote-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.trend-card {
  padding: 28rpx;
}

.trend-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.latest-price {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4fa;
  color: #133a5e;
  font-size: 28rpx;
  font-weight: 900;
}

.line-chart {
  position: relative;
  margin-top: 22rpx;
  padding: 18rpx 0 4rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f6f9fc 0%, #ffffff 100%);
  border: 1rpx solid #e4ebf2;
  overflow: hidden;
}

.trend-canvas {
  display: block;
  width: 100%;
  height: 260rpx;
}

.axis-price {
  position: absolute;
  left: 18rpx;
  z-index: 1;
  font-size: 20rpx;
  color: #8a98ab;
  background: rgba(246, 249, 252, 0.86);
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
}

.axis-high {
  top: 12rpx;
}

.axis-low {
  bottom: 52rpx;
}

.chart-labels {
  display: grid;
  grid-template-columns: repeat(8, minmax(0, 1fr));
  gap: 4rpx;
  padding: 0 12rpx 10rpx;
}

.chart-labels text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  font-size: 19rpx;
  color: #6d7f93;
}
