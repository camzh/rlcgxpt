.mine-page {
  padding-top: 24rpx;
}

.profile-panel {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #133a5e;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.profile-info {
  flex: 1;
}

.name {
  font-size: 34rpx;
  font-weight: 800;
  color: #17324d;
}

.mine-kpis {
  margin-top: 18rpx;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(128rpx, 1fr));
  gap: 10rpx;
}

.kpi-card {
  padding: 18rpx 8rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e4ebf2;
  text-align: center;
}

.kpi-value {
  display: block;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #133a5e;
}

.kpi-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d7f93;
}

.mine-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.admin-tools {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.admin-tool-button {
  min-height: 76rpx;
  line-height: 76rpx;
}

.mine-item {
  margin-top: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.mine-item-main {
  flex: 1;
  min-width: 0;
}

.mine-item-status {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 88rpx;
}

.mine-item-status .status-tag {
  white-space: nowrap;
  word-break: keep-all;
  writing-mode: horizontal-tb;
  flex-direction: row;
}

.mine-title {
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #17324d;
}

.mine-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #6d7f93;
  word-break: break-word;
}

.show-more-button {
  width: 100%;
  margin: 18rpx 0 0;
  padding: 0;
  min-height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: #f6f9fc;
  color: #133a5e;
  border: 1rpx solid #dfe8f1;
  font-size: 26rpx;
  font-weight: 700;
}

.show-more-button::after,
.collapse-fixed-button::after {
  border: 0;
}

.collapse-fixed-button {
  position: fixed;
  right: 28rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 20;
  width: 144rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #133a5e;
  color: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(19, 58, 94, 0.22);
  font-size: 26rpx;
  font-weight: 800;
}
.growth-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.growth-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.trend-legend {
  display: flex;
  gap: 14rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #6d7f93;
}

.legend-dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  margin-right: 6rpx;
  border-radius: 50%;
}

.publish-dot {
  background: #133a5e;
}

.sold-dot {
  background: #c25c39;
}

.trend-chart {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 26rpx;
  padding: 22rpx 12rpx 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f6f9fc 0%, #ffffff 100%);
  border: 1rpx solid #e4ebf2;
}

.trend-day {
  min-width: 0;
  text-align: center;
}

.bar-wrap {
  height: 156rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 5rpx;
  padding: 0 4rpx;
  border-bottom: 1rpx solid #dfe8f1;
}

.trend-bar {
  width: 14rpx;
  min-height: 8rpx;
  border-radius: 999rpx 999rpx 0 0;
}

.publish-bar {
  background: linear-gradient(180deg, #2f6997 0%, #133a5e 100%);
}

.sold-bar {
  background: linear-gradient(180deg, #df8a63 0%, #c25c39 100%);
}

.trend-counts {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #17324d;
  font-weight: 700;
}

.trend-label {
  margin-top: 4rpx;
  font-size: 19rpx;
  color: #8a98ab;
}

.growth-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.growth-grid > view {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f6f9fc;
}

.growth-value {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 900;
}

.growth-up {
  color: #1f8a5b;
}

.growth-down {
  color: #c25c39;
}
.approval-entry-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.approval-entry-card .admin-tool-button {
  width: 172rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0;
  font-size: 24rpx;
}

.kpi-card.kpi-active {
  border-color: #133a5e;
  background: #eef4fa;
}

.metric-card {
  margin-top: 18rpx;
}
