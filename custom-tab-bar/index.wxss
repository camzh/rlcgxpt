.tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -8rpx 24rpx rgba(19, 58, 94, 0.08);
}

.tabbar {
  height: 112rpx;
  display: flex;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #eef3f8;
  color: #6b7a90;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.tab-icon-active {
  background: #133a5e;
  color: #ffffff;
}

.tab-label {
  font-size: 24rpx;
  color: #6b7a90;
  font-weight: 600;
}

.tab-label-active {
  color: #133a5e;
}
